logging:
  file:
    enable: true
    level: INFO
    path: logs
    rotation: "10 MB"
    retention: "7 days"
  console:
    enable: true
    level: INFO

db_meta:
  host: 127.0.0.1
  port: 3306
  user: root
  password: "your_password_here"
  database: meta

db_dw:
  host: 127.0.0.1
  port: 3306
  user: root
  password: "your_password_here"
  database: travel

qdrant:
  host: 127.0.0.1
  port: 6333
  embedding_size: 1024

embedding:
  model_path: /path/to/bge-large-zh-v1.5

es:
  host: 127.0.0.1
  port: 9200
  index_name: data_agent

llm:
  model_name: deepseek-v4-flash
  api_key: your_api_key_here
  base_url: https://api.deepseek.com
